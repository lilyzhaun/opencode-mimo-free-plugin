{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-mimo-free-plugin",
  "version": "0.1.1",
  "description": "OpenCode plugin that injects the MiMo Auto free OpenAI-compatible provider.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lilyzhaun/opencode-mimo-free-plugin.git"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "mimo",
    "llm"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.3",
    "@types/bun": "^1.3.3",
    "@types/node": "^22.19.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "opencode": ">=1.17.0"
  }
}
